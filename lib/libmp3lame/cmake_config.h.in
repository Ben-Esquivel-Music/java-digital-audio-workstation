/* config.h — generated by CMake from cmake_config.h.in */
#ifndef LAME_CONFIG_H
#define LAME_CONFIG_H

/* Standard C header availability */
#cmakedefine STDC_HEADERS 1
#cmakedefine HAVE_STDINT_H 1
#cmakedefine HAVE_INTTYPES_H 1
#cmakedefine HAVE_SYS_TYPES_H 1
#cmakedefine HAVE_SYS_STAT_H 1
#cmakedefine HAVE_MEMORY_H 1
#cmakedefine HAVE_STDLIB_H 1
#cmakedefine HAVE_STRING_H 1
#cmakedefine HAVE_STRINGS_H 1
#cmakedefine HAVE_UNISTD_H 1
#cmakedefine HAVE_ERRNO_H 1
#cmakedefine HAVE_FCNTL_H 1
#cmakedefine HAVE_LIMITS_H 1
#cmakedefine HAVE_DLFCN_H 1
#cmakedefine HAVE_XMMINTRIN_H 1

/* Function availability */
#cmakedefine HAVE_STRCHR 1
#cmakedefine HAVE_MEMCPY 1
#cmakedefine HAVE_STRTOL 1
#cmakedefine HAVE_SOCKET 1

/* Type sizes */
#define SIZEOF_SHORT       @SIZEOF_SHORT@
#define SIZEOF_INT         @SIZEOF_INT@
#define SIZEOF_LONG        @SIZEOF_LONG@
#define SIZEOF_LONG_LONG   @SIZEOF_LONG_LONG@
#define SIZEOF_FLOAT       @SIZEOF_FLOAT@
#define SIZEOF_DOUBLE      @SIZEOF_DOUBLE@
#define SIZEOF_LONG_DOUBLE @SIZEOF_LONG_DOUBLE@
#define SIZEOF_UNSIGNED_SHORT     @SIZEOF_UNSIGNED_SHORT@
#define SIZEOF_UNSIGNED_INT       @SIZEOF_UNSIGNED_INT@
#define SIZEOF_UNSIGNED_LONG      @SIZEOF_UNSIGNED_LONG@
#define SIZEOF_UNSIGNED_LONG_LONG @SIZEOF_UNSIGNED_LONG_LONG@

/* Standard integer types (modern compilers always have these) */
#ifdef HAVE_STDINT_H
# include <stdint.h>
#endif
#define HAVE_INT8_T   1
#define HAVE_INT16_T  1
#define HAVE_INT32_T  1
#define HAVE_INT64_T  1
#define HAVE_UINT8_T  1
#define HAVE_UINT16_T 1
#define HAVE_UINT32_T 1
#define HAVE_UINT64_T 1

/* IEEE float types — not provided by the system, so typedef them here */
typedef float       ieee754_float32_t;
typedef double      ieee754_float64_t;
typedef long double ieee854_float80_t;

/* Build configuration */
#define HAVE_MPGLIB          1
#define DECODE_ON_THE_FLY    1
#define USE_FAST_LOG         1
#define LAME_LIBRARY_BUILD   1
#define NOANALYSIS           1
#define NDEBUG               1
#define TAKEHIRO_IEEE754_HACK 1

/* Compiler function prototypes */
#define PROTOTYPES 1

/* Package info */
#define PACKAGE "lame"
#define PACKAGE_NAME "lame"
#define PACKAGE_VERSION "3.99.5"
#define PACKAGE_STRING "lame 3.99.5"
#define VERSION "3.99.5"

#endif /* LAME_CONFIG_H */
