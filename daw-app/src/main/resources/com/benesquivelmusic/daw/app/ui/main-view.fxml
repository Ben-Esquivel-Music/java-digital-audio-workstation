<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.benesquivelmusic.daw.app.ui.MainController"
            styleClass="root-pane">

    <!-- Top: Transport Controls -->
    <top>
        <VBox>
            <HBox alignment="CENTER" spacing="8" styleClass="transport-bar">
                <padding>
                    <Insets top="8" right="16" bottom="8" left="16"/>
                </padding>

                <!-- Transport (icons applied programmatically via IconNode) -->
                <Button fx:id="skipBackButton" text="Skip Back" onAction="#onSkipBack"
                        styleClass="transport-button"/>
                <Button fx:id="playButton" text="Play" onAction="#onPlay"
                        styleClass="transport-button, play-button"/>
                <Button fx:id="pauseButton" text="Pause" onAction="#onPause"
                        styleClass="transport-button, pause-button"/>
                <Button fx:id="stopButton" text="Stop" onAction="#onStop"
                        styleClass="transport-button, stop-button"/>
                <Button fx:id="recordButton" text="Record" onAction="#onRecord"
                        styleClass="transport-button, record-button"/>
                <Button fx:id="skipForwardButton" text="Skip Forward" onAction="#onSkipForward"
                        styleClass="transport-button"/>
                <Button fx:id="loopButton" text="Loop" onAction="#onToggleLoop"
                        styleClass="transport-button, loop-button"/>

                <Separator orientation="VERTICAL"/>

                <!-- Time display (icon applied programmatically) -->
                <Label fx:id="timeDisplay" text="00:00:00.0" styleClass="time-display"/>

                <Separator orientation="VERTICAL"/>

                <!-- Tempo (icon applied programmatically) -->
                <Label fx:id="tempoLabel" text="120.0 BPM" styleClass="tempo-label"/>

                <Separator orientation="VERTICAL"/>

                <!-- Track controls (icons applied programmatically) -->
                <Button fx:id="addAudioTrackButton" text="Audio Track" onAction="#onAddAudioTrack"
                        styleClass="transport-button"/>
                <Button fx:id="addMidiTrackButton" text="MIDI Track" onAction="#onAddMidiTrack"
                        styleClass="transport-button"/>

                <Separator orientation="VERTICAL"/>

                <!-- Undo / Redo (icons applied programmatically) -->
                <Button fx:id="undoButton" text="Undo" onAction="#onUndo"
                        styleClass="transport-button"/>
                <Button fx:id="redoButton" text="Redo" onAction="#onRedo"
                        styleClass="transport-button"/>

                <Separator orientation="VERTICAL"/>

                <!-- Project / Plugins (icons applied programmatically) -->
                <Button fx:id="saveButton" text="Save" onAction="#onSaveProject"
                        styleClass="transport-button, project-button"/>
                <Button fx:id="pluginsButton" text="Plugins" onAction="#onManagePlugins"
                        styleClass="transport-button, plugin-button"/>

                <!-- Spacer -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Status (icon applied programmatically) -->
                <Label fx:id="statusLabel" text="STOPPED" styleClass="status-label"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>

    <!-- Left: Sidebar Toolbar -->
    <left>
        <VBox fx:id="sidebarToolbar" styleClass="sidebar-toolbar" alignment="TOP_CENTER">
            <padding>
                <Insets top="8" right="4" bottom="8" left="4"/>
            </padding>

            <!-- View Navigation -->
            <Button fx:id="arrangementViewButton" text="Arrangement"
                    styleClass="sidebar-button"/>
            <Button fx:id="mixerViewButton" text="Mixer"
                    styleClass="sidebar-button"/>
            <Button fx:id="editorViewButton" text="Editor"
                    styleClass="sidebar-button"/>

            <Separator styleClass="sidebar-separator"/>

            <!-- Project Management -->
            <Button fx:id="projectFolderButton" text="Project"
                    styleClass="sidebar-button"/>
            <Button fx:id="browserButton" text="Browser"
                    styleClass="sidebar-button"/>

            <Separator styleClass="sidebar-separator"/>

            <!-- Settings -->
            <Button fx:id="settingsButton" text="Settings"
                    styleClass="sidebar-button"/>
        </VBox>
    </left>

    <!-- Center: Tiled Content Area -->
    <center>
        <VBox styleClass="content-area" spacing="6">
            <!-- Upper row: Track List + Arrangement tiles -->
            <SplitPane dividerPositions="0.22" styleClass="main-split" VBox.vgrow="ALWAYS">
                <!-- Left: Track List Tile -->
                <VBox fx:id="trackListPanel" styleClass="track-list-panel">
                    <padding>
                        <Insets top="8" right="8" bottom="8" left="8"/>
                    </padding>
                    <Label fx:id="tracksPanelHeader" text="TRACKS" styleClass="panel-header"/>
                </VBox>

                <!-- Right: Arrangement Timeline Tile -->
                <VBox styleClass="arrangement-panel">
                    <HBox styleClass="timeline-header" alignment="CENTER_LEFT" spacing="20">
                        <Label fx:id="arrangementPanelHeader" text="ARRANGEMENT"
                               styleClass="panel-header"/>
                        <Label text="1" styleClass="timeline-label"/>
                        <Label text="2" styleClass="timeline-label"/>
                        <Label text="3" styleClass="timeline-label"/>
                        <Label text="4" styleClass="timeline-label"/>
                        <Label text="5" styleClass="timeline-label"/>
                        <Label text="6" styleClass="timeline-label"/>
                        <Label text="7" styleClass="timeline-label"/>
                        <Label text="8" styleClass="timeline-label"/>
                    </HBox>
                    <StackPane VBox.vgrow="ALWAYS">
                        <Label fx:id="arrangementPlaceholder"
                               text="Add tracks to begin your session"
                               styleClass="placeholder-label"/>
                    </StackPane>
                </VBox>
            </SplitPane>

            <!-- Lower row: Visualization Display Tiles -->
            <HBox fx:id="vizTileRow" styleClass="viz-tile-row" spacing="6">
                <!-- Tiles added programmatically by MainController -->
            </HBox>
        </VBox>
    </center>

    <!-- Bottom: Status Bar -->
    <bottom>
        <VBox>
            <Separator/>
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="status-bar">
                <padding>
                    <Insets top="4" right="16" bottom="4" left="16"/>
                </padding>
                <Label fx:id="projectInfoLabel" text="Untitled Project  ·  96 kHz / 24-bit"
                       styleClass="project-info-label"/>
                <Separator orientation="VERTICAL"/>
                <Label fx:id="monitoringLabel" text="Monitoring"
                       styleClass="status-bar-label"/>
                <Separator orientation="VERTICAL"/>
                <Label fx:id="ioRoutingLabel" text="I/O"
                       styleClass="status-bar-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="checkpointLabel" text="Auto-save: ON"
                       styleClass="checkpoint-label"/>
                <Separator orientation="VERTICAL"/>
                <Label fx:id="statusBarLabel" text="Ready" styleClass="status-bar-label"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
