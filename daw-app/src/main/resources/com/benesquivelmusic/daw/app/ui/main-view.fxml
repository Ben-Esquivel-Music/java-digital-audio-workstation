<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import com.benesquivelmusic.daw.app.ui.inspector.InspectorDrawer?>
<BorderPane fx:id="rootPane"
            xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.benesquivelmusic.daw.app.ui.MainController"
            styleClass="root-pane">

    <!-- Top: Transport Controls -->
    <top>
        <VBox>
            <HBox alignment="CENTER" spacing="8" styleClass="transport-bar">
                <padding>
                    <Insets top="8" right="16" bottom="8" left="16"/>
                </padding>

                <!-- Group 1: Transport — text-only per UI Design Book §2.4
                     ("an icon is a replacement for a label, not a decoration
                     on it"). Icons would compete with the labels (§1.4). -->
                <HBox fx:id="transportGroup" spacing="4" alignment="CENTER"
                      styleClass="toolbar-button-group">
                    <Button fx:id="skipBackButton" text="Skip Back" onAction="#onSkipBack"
                            styleClass="dawg-button, size-transport"/>
                    <Button fx:id="playButton" text="Play" onAction="#onPlay"
                            styleClass="dawg-button, size-transport"/>
                    <Button fx:id="stopButton" text="Stop" onAction="#onStop"
                            styleClass="dawg-button, size-transport"/>
                    <Button fx:id="recordButton" text="Record" onAction="#onRecord"
                            styleClass="dawg-button, size-transport, danger, record-button"/>
                    <Button fx:id="skipForwardButton" text="Skip Forward" onAction="#onSkipForward"
                            styleClass="dawg-button, size-transport"/>
                    <Button fx:id="loopButton" text="Loop" onAction="#onToggleLoop"
                            styleClass="dawg-button, size-transport, loop-button"/>
                </HBox>

                <Separator orientation="VERTICAL"/>

                <!-- Time display — text-only per §2.4 (no decorative icon).
                     Composes .time-display (colour + min-width) with
                     .numeric-display (mono 14 px / 500) — story 266 / §3.2. -->
                <Label fx:id="timeDisplay" text="00:00:00.0"
                       styleClass="time-display, numeric-display"/>

                <Separator orientation="VERTICAL"/>

                <!-- Tempo — text-only per §2.4. Composes .tempo-label
                     (warn-colour) with .numeric-value (mono 12 px / 500) —
                     story 266 / §3.2. -->
                <Label fx:id="tempoLabel" text="120.0 BPM"
                       styleClass="tempo-label, numeric-value"/>

                <!-- Metronome — labelled button (text-only per §2.4) -->
                <Button fx:id="metronomeButton" text="Metronome" onAction="#onToggleMetronome"
                        styleClass="dawg-button, size-transport, metronome-button"/>

                <Separator orientation="VERTICAL" visible="false" managed="false"/>

                <!-- Group 2: Track controls (available via Edit menu shortcuts) -->
                <HBox fx:id="trackGroup" spacing="4" alignment="CENTER"
                      styleClass="toolbar-button-group"
                      visible="false" managed="false">
                    <Button fx:id="addAudioTrackButton" text="Audio Track" onAction="#onAddAudioTrack"
                            styleClass="dawg-button, size-transport"/>
                    <Button fx:id="addMidiTrackButton" text="MIDI Track" onAction="#onAddMidiTrack"
                            styleClass="dawg-button, size-transport"/>
                </HBox>

                <!-- Group 3: Undo / Redo (available via Edit menu) -->
                <HBox fx:id="undoRedoGroup" spacing="4" alignment="CENTER"
                      styleClass="toolbar-button-group"
                      visible="false" managed="false">
                    <Button fx:id="undoButton" text="Undo" onAction="#onUndo"
                            styleClass="dawg-button, size-transport"/>
                    <Button fx:id="redoButton" text="Redo" onAction="#onRedo"
                            styleClass="dawg-button, size-transport"/>
                </HBox>

                <!-- Group 4: Snap, Save, Plugins (available via menus) -->
                <HBox fx:id="utilityGroup" spacing="4" alignment="CENTER"
                      styleClass="toolbar-button-group"
                      visible="false" managed="false">
                    <Button fx:id="snapButton" text="Snap"
                            styleClass="dawg-button, size-transport"/>
                    <Button fx:id="saveButton" text="Save" onAction="#onSaveProject"
                            styleClass="dawg-button, size-transport, project-button"/>
                    <Button fx:id="pluginsButton" text="Plugins" onAction="#onManagePlugins"
                            styleClass="dawg-button, size-transport, plugin-button"/>
                </HBox>

                <!-- Ripple Edit Mode cycling button (Story 138) -->
                <Button fx:id="rippleModeButton" text="Ripple: Off"
                        styleClass="dawg-button, size-transport, ripple-mode-button, ripple-off"/>

                <!-- REC indicator (visible only during recording) -->
                <Label fx:id="recIndicator" text="● REC" styleClass="rec-indicator"
                       visible="false" managed="false"/>

                <!-- Spacer -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Status — text-only per §2.4 -->
                <Label fx:id="statusLabel" text="STOPPED" styleClass="status-label"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>

    <!-- Center: Tiled Content Area -->
    <center>
        <VBox styleClass="content-area" spacing="8">
            <!-- Upper row: Track List + Arrangement tiles -->
            <SplitPane dividerPositions="0.22" styleClass="main-split" VBox.vgrow="ALWAYS">
                <!-- Left: Track List Tile -->
                <VBox fx:id="trackListPanel" styleClass="track-list-panel">
                    <padding>
                        <Insets top="8" right="8" bottom="8" left="8"/>
                    </padding>
                    <Label fx:id="tracksPanelHeader" text="TRACKS" styleClass="panel-header"/>
                </VBox>

                <!-- Right: Arrangement Timeline Tile -->
                <VBox styleClass="arrangement-panel">
                    <HBox styleClass="timeline-header" alignment="CENTER_LEFT" spacing="20">
                        <Label fx:id="arrangementPanelHeader" text="ARRANGEMENT"
                               styleClass="panel-header"/>
                        <!-- Beat markers — .timeline-label keeps the muted
                             text-fill, .numeric-caption supplies the mono
                             11 px typography (story 266 / §3.2). -->
                        <Label text="1" styleClass="timeline-label, numeric-caption"/>
                        <Label text="2" styleClass="timeline-label, numeric-caption"/>
                        <Label text="3" styleClass="timeline-label, numeric-caption"/>
                        <Label text="4" styleClass="timeline-label, numeric-caption"/>
                        <Label text="5" styleClass="timeline-label, numeric-caption"/>
                        <Label text="6" styleClass="timeline-label, numeric-caption"/>
                        <Label text="7" styleClass="timeline-label, numeric-caption"/>
                        <Label text="8" styleClass="timeline-label, numeric-caption"/>
                    </HBox>
                    <StackPane fx:id="arrangementContentPane" VBox.vgrow="ALWAYS">
                        <Label fx:id="arrangementPlaceholder"
                               text="Add tracks to begin your session"
                               styleClass="placeholder-label"/>
                    </StackPane>
                </VBox>
            </SplitPane>

            <!-- Lower row: Visualization Display Tiles -->
            <HBox fx:id="vizTileRow" styleClass="viz-tile-row" spacing="8">
                <!-- Tiles added programmatically by MainController -->
            </HBox>
        </VBox>
    </center>

    <!-- Right: Unified Inspector Drawer (UI Design Book §5.6, story 272).
         Hosts the Track / Inserts / Sends / Routing / Notes sections.
         Collapsible to a 24 px rail; expanded width 240 px. The drawer
         consumes TrackSelectionEvent / InsertSelectedEvent /
         SendSelectedEvent from the source-side controls via
         installSourceEventForwarding(rootPane) wired in MainController. -->
    <right>
        <InspectorDrawer fx:id="inspectorDrawer"/>
    </right>

    <!-- Bottom: Notification Bar + Status Bar -->
    <bottom>
        <VBox>
            <Separator/>
            <HBox fx:id="notificationBarContainer"/>
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="status-bar">
                <padding>
                    <Insets top="4" right="16" bottom="4" left="16"/>
                </padding>
                <!-- projectInfoLabel and ioRoutingLabel get rewritten at runtime
                     to "… 96 kHz / 24-bit / 8ch" and "96 kHz I/O" by
                     MainController#applyProjectInfoLabels(...) — story 266 /
                     §3.2 numeric class so the sample-rate / bit-depth / channel
                     digits use tabular figures. -->
                <Label fx:id="projectInfoLabel" text="Untitled Project  ·  96 kHz / 24-bit"
                       styleClass="project-info-label, numeric-caption"/>
                <Separator orientation="VERTICAL"/>
                <Label fx:id="monitoringLabel" text="Monitoring"
                       styleClass="status-bar-label"/>
                <Separator orientation="VERTICAL"/>
                <Label fx:id="ioRoutingLabel" text="I/O"
                       styleClass="status-bar-label, numeric-caption"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="checkpointLabel" text="Auto-save: ON"
                       styleClass="checkpoint-label"/>
                <Separator orientation="VERTICAL"/>
                <!-- Ripple-mode red banner (visible only when ripple is active) -->
                <Label fx:id="rippleBannerLabel" text="" styleClass="ripple-banner"
                       visible="false" managed="false"/>
                <Label fx:id="statusBarLabel" text="Ready" styleClass="status-bar-label"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
