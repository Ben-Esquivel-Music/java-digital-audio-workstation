<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.control.SplitPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>
<?import javafx.scene.layout.StackPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane xmlns="http://javafx.com/javafx"
            xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.benesquivelmusic.daw.app.ui.MainController"
            styleClass="root-pane">

    <!-- Top: Transport Controls -->
    <top>
        <VBox>
            <HBox alignment="CENTER" spacing="8" styleClass="transport-bar">
                <padding>
                    <Insets top="8" right="16" bottom="8" left="16"/>
                </padding>

                <!-- Transport -->
                <Button fx:id="playButton" text="▶ Play" onAction="#onPlay"
                        styleClass="transport-button, play-button"/>
                <Button fx:id="stopButton" text="■ Stop" onAction="#onStop"
                        styleClass="transport-button, stop-button"/>
                <Button fx:id="recordButton" text="● Record" onAction="#onRecord"
                        styleClass="transport-button, record-button"/>

                <Separator orientation="VERTICAL"/>

                <!-- Time display -->
                <Label fx:id="timeDisplay" text="00:00:00.0" styleClass="time-display"/>

                <Separator orientation="VERTICAL"/>

                <!-- Tempo -->
                <Label fx:id="tempoLabel" text="120.0 BPM" styleClass="tempo-label"/>

                <Separator orientation="VERTICAL"/>

                <!-- Track controls -->
                <Button text="＋ Audio Track" onAction="#onAddAudioTrack"
                        styleClass="transport-button"/>
                <Button text="＋ MIDI Track" onAction="#onAddMidiTrack"
                        styleClass="transport-button"/>

                <Separator orientation="VERTICAL"/>

                <!-- Project / Plugins -->
                <Button text="💾 Save" onAction="#onSaveProject"
                        styleClass="transport-button, project-button"/>
                <Button text="🔌 Plugins" onAction="#onManagePlugins"
                        styleClass="transport-button, plugin-button"/>

                <!-- Spacer -->
                <Region HBox.hgrow="ALWAYS"/>

                <!-- Status -->
                <Label fx:id="statusLabel" text="STOPPED" styleClass="status-label"/>
            </HBox>
            <Separator/>
        </VBox>
    </top>

    <!-- Center: Track Area / Arrangement View -->
    <center>
        <SplitPane dividerPositions="0.22" styleClass="main-split">
            <!-- Left: Track List -->
            <VBox fx:id="trackListPanel" styleClass="track-list-panel">
                <padding>
                    <Insets top="8" right="8" bottom="8" left="8"/>
                </padding>
                <Label text="🎚 TRACKS" styleClass="panel-header"/>
            </VBox>

            <!-- Right: Arrangement Timeline -->
            <VBox styleClass="arrangement-panel">
                <HBox styleClass="timeline-header" alignment="CENTER_LEFT" spacing="20">
                    <Label text="1" styleClass="timeline-label"/>
                    <Label text="2" styleClass="timeline-label"/>
                    <Label text="3" styleClass="timeline-label"/>
                    <Label text="4" styleClass="timeline-label"/>
                    <Label text="5" styleClass="timeline-label"/>
                    <Label text="6" styleClass="timeline-label"/>
                    <Label text="7" styleClass="timeline-label"/>
                    <Label text="8" styleClass="timeline-label"/>
                </HBox>
                <StackPane VBox.vgrow="ALWAYS">
                    <Label fx:id="arrangementPlaceholder"
                           text="🎵  Add tracks to begin your session"
                           styleClass="placeholder-label"/>
                </StackPane>
            </VBox>
        </SplitPane>
    </center>

    <!-- Bottom: Status Bar -->
    <bottom>
        <VBox>
            <Separator/>
            <HBox alignment="CENTER_LEFT" spacing="16" styleClass="status-bar">
                <padding>
                    <Insets top="4" right="16" bottom="4" left="16"/>
                </padding>
                <Label fx:id="projectInfoLabel" text="Untitled Project  ·  96 kHz / 24-bit"
                       styleClass="project-info-label"/>
                <Region HBox.hgrow="ALWAYS"/>
                <Label fx:id="checkpointLabel" text="Auto-save: ON"
                       styleClass="checkpoint-label"/>
                <Separator orientation="VERTICAL"/>
                <Label fx:id="statusBarLabel" text="Ready" styleClass="status-bar-label"/>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
